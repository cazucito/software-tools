---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Buscar" description="Busca herramientas por nombre, tags, categoría o año">
  <Header slot="header" />
  
  <div class="max-w-4xl mx-auto">
    <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">
      Buscar herramientas
    </h1>
    <p class="text-slate-400 mb-8">
      Busca por nombre, tags, categoría o año
    </p>

    <!-- Search Box -->
    <div class="relative mb-8" id="search-container">
      <div class="relative">
        <input
          type="text"
          id="search-input"
          placeholder="Escribe para buscar..."
          class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-4 pl-12 text-lg text-white placeholder-slate-500 focus:outline-none focus:border-sky-500 focus:ring-2 focus:ring-sky-500/50"
          autocomplete="off"
          autofocus
        />
        <svg
          class="absolute left-4 top-1/2 -translate-y-1/2 w-6 h-6 text-slate-500"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
          />
        </svg>
      </div>
    </div>

    <!-- Resultados -->
    <div id="search-results" class="space-y-4">
      <div class="text-center py-12 text-slate-500">
        <p>Escribe arriba para buscar herramientas</p>
        <p class="text-sm mt-2">Prueba: "dos", "editor", "1995", "java"</p>
      </div>
    </div>

    <!-- Stats -->
    <div id="search-stats" class="mt-8 pt-8 border-t border-slate-800 text-sm text-slate-500 hidden">
      <!-- Se actualiza con JavaScript -->
    </div>
  </div>

  <Footer slot="footer" />

  <script>
    import Fuse from 'fuse.js';

    interface SearchItem {
      name: string;
      slug: string;
      year: number;
      decade: string;
      category: string;
      tags: string[];
      context: string;
    }

    let fuse: Fuse<SearchItem> | null = null;
    let searchIndex: SearchItem[] = [];

    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const searchResults = document.getElementById('search-results') as HTMLDivElement;
    const searchStats = document.getElementById('search-stats') as HTMLDivElement;

    // Cargar índice
    async function loadSearchIndex() {
      try {
        const response = await fetch('/software-tools/search-index.json');
        searchIndex = await response.json();
        
        fuse = new Fuse(searchIndex, {
          keys: [
            { name: 'name', weight: 0.4 },
            { name: 'tags', weight: 0.3 },
            { name: 'context', weight: 0.2 },
            { name: 'category', weight: 0.1 },
          ],
          threshold: 0.3,
          includeScore: true,
          includeMatches: true,
        });

        // Check for query param
        const urlParams = new URLSearchParams(window.location.search);
        const query = urlParams.get('q');
        if (query) {
          searchInput.value = query;
          performSearch(query);
        }
      } catch (error) {
        console.error('Error cargando índice de búsqueda:', error);
        searchResults.innerHTML = `
          <div class="text-center py-12 text-red-400">
            Error cargando el índice de búsqueda
          </div>
        `;
      }
    }

    // Realizar búsqueda
    function performSearch(query: string) {
      if (!fuse || !query.trim()) {
        searchResults.innerHTML = `
          <div class="text-center py-12 text-slate-500">
            <p>Escribe arriba para buscar herramientas</p>
            <p class="text-sm mt-2">Prueba: "dos", "editor", "1995", "java"</p>
          </div>
        `;
        searchStats.classList.add('hidden');
        return;
      }

      const results = fuse.search(query);

      if (results.length === 0) {
        searchResults.innerHTML = `
          <div class="text-center py-12">
            <p class="text-slate-400">No se encontraron resultados para "${query}"</p>
            <p class="text-sm text-slate-500 mt-2">
              Prueba con términos más generales o revisa la ortografía
            </p>
          </div>
        `;
        searchStats.classList.remove('hidden');
        searchStats.textContent = `0 resultados`;
        return;
      }

      const html = results.map(result => {
        const tool = result.item;
        const score = Math.round((1 - (result.score || 0)) * 100);
        
        return `
          <a
            href="/software-tools/tools/${tool.slug}"
            class="block bg-slate-800 hover:bg-slate-750 border border-slate-700 rounded-lg p-6 transition-all hover:border-sky-500/50 group"
          >
            <div class="flex items-start justify-between mb-3">
              <div>
                <h3 class="text-xl font-semibold text-white group-hover:text-sky-400 transition-colors">
                  ${tool.name}
                </h3>
                <p class="text-slate-400 mt-1">${tool.context || 'Sin descripción'}</p>
              </div>
              <div class="text-right shrink-0 ml-4">
                <span class="text-lg font-bold text-sky-400">${tool.year}</span>
                <span class="text-xs text-slate-500 block">${tool.decade}</span>
              </div>
            </div>
            <div class="flex flex-wrap items-center gap-3 mt-4">
              <span class="text-xs text-slate-500 uppercase tracking-wide bg-slate-900 px-2 py-1 rounded">
                ${tool.category}
              </span>
              ${tool.tags.slice(0, 4).map(tag => `
                <span class="text-xs text-slate-400">#${tag}</span>
              `).join('')}
            </div>
          </a>
        `;
      }).join('');

      searchResults.innerHTML = html;
      searchStats.classList.remove('hidden');
      searchStats.textContent = `${results.length} resultado${results.length !== 1 ? 's' : ''}`;

      // Update URL
      const url = new URL(window.location.href);
      url.searchParams.set('q', query);
      window.history.replaceState({}, '', url);
    }

    // Event listeners
    let debounceTimer: ReturnType<typeof setTimeout>;
    searchInput?.addEventListener('input', (e) => {
      clearTimeout(debounceTimer);
      const query = (e.target as HTMLInputElement).value;
      debounceTimer = setTimeout(() => performSearch(query), 150);
    });

    // Cargar índice al iniciar
    loadSearchIndex();
  </script>
</Layout>