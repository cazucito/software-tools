---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from '../../utils/collection';

export async function getStaticPaths() {
  const tools = await getCollection('tools');
  const decades = [...new Set(tools.filter(t => t.published).map(t => t.decade))];
  
  return decades.map(decade => ({
    params: { decade },
    props: { decade },
  }));
}

const { decade } = Astro.params;
const tools = await getCollection('tools');
const decadeTools = tools
  .filter(t => t.published && t.decade === decade)
  .sort((a, b) => b.year - a.year);

const startYear = parseInt(decade);
const endYear = startYear + 9;
const decadeLabel = `${startYear}-${endYear}`;
---

<Layout title={`Década ${decade}`} description={`Herramientas utilizadas en la década ${decadeLabel}`}>
  <Header slot="header" />
  
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-4">
        {decade}
      </h1>
      <p class="text-xl text-slate-400">
        {decadeTools.length} herramientas • {decadeLabel}
      </p>
    </div>

    <!-- Timeline visual -->
    <div class="relative mb-16">
      <!-- Línea central -->
      <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-0.5 bg-slate-700 md:-translate-x-px"></div>
      
      <!-- Tools -->
      <div class="space-y-8">
        {decadeTools.map((tool, index) => {
          const isEven = index % 2 === 0;
          return (
            <div class={`relative flex items-start ${isEven ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
              <!-- Punto en la línea -->
              <div class="absolute left-4 md:left-1/2 w-3 h-3 bg-sky-500 rounded-full border-2 border-slate-800 md:-translate-x-1.5 mt-2 z-10"></div>
              
              <!-- Contenido -->
              <div class={`ml-12 md:ml-0 md:w-1/2 ${isEven ? 'md:pr-8 md:text-right' : 'md:pl-8'}`}>
                <a 
                  href={`/tools/${tool.slug}`}
                  class="block bg-slate-800 hover:bg-slate-750 border border-slate-700 rounded-lg p-6 transition-all hover:border-sky-500/50 group"
                >
                  <div class={`flex items-center gap-2 mb-2 ${isEven ? 'md:justify-end' : ''}`}>
                    <span class="text-2xl font-bold text-sky-400">{tool.year}</span>
                    <span class="text-sm text-slate-500 uppercase tracking-wide">{tool.category}</span>
                  </div>
                  <h3 class={`text-xl font-semibold text-white group-hover:text-sky-400 transition-colors mb-2 ${isEven ? 'md:text-right' : ''}`}>
                    {tool.name}
                  </h3>
                  {tool.context && (
                    <p class={`text-slate-400 text-sm line-clamp-2 ${isEven ? 'md:text-right' : ''}`}>
                      {tool.context}
                    </p>
                  )}
                  <div class={`flex flex-wrap gap-2 mt-4 ${isEven ? 'md:justify-end' : ''}`}>
                    {tool.tags.slice(0, 3).map(tag => (
                      <span class="text-xs text-slate-500 bg-slate-900 px-2 py-1 rounded">
                        #{tag}
                      </span>
                    ))}
                  </div>
                </a>
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- Navegación entre décadas -->
    <div class="flex justify-between items-center border-t border-slate-800 pt-8">
      {startYear > 1990 && (
        <a 
          href={`/decade/${startYear - 10}s`}
          class="text-slate-400 hover:text-sky-400 flex items-center gap-2 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          {startYear - 10}s
        </a>
      )}
      <a 
        href="/"
        class="text-slate-400 hover:text-sky-400 mx-auto"
      >
        ← Inicio
      </a>
      {endYear < 2025 && (
        <a 
          href={`/decade/${startYear + 10}s`}
          class="text-slate-400 hover:text-sky-400 flex items-center gap-2 transition-colors"
        >
          {startYear + 10}s
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      )}
    </div>
  </div>

  <Footer slot="footer" />
</Layout>