---
// Componente de búsqueda con Fuse.js
---

<div class="relative" id="search-container">
  <div class="relative">
    <input
      type="text"
      id="search-input"
      placeholder="Buscar herramientas..."
      class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3 pl-11 text-white placeholder-slate-500 focus:outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500"
      autocomplete="off"
    />
    <svg
      class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-500"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
      />
    </svg>
    <kbd class="absolute right-3 top-1/2 -translate-y-1/2 hidden md:block text-xs text-slate-500 bg-slate-900 px-2 py-1 rounded">
      /
    </kbd>
  </div>

  <!-- Resultados -->
  <div
    id="search-results"
    class="absolute top-full left-0 right-0 mt-2 bg-slate-800 border border-slate-700 rounded-lg shadow-xl max-h-96 overflow-y-auto hidden z-50"
  >
    <!-- Los resultados se insertan aquí -->
  </div>
</div>

<script>
  import Fuse from 'fuse.js';

  interface SearchItem {
    name: string;
    slug: string;
    year: number;
    decade: string;
    category: string;
    tags: string[];
    context: string;
  }

  let fuse: Fuse<SearchItem> | null = null;
  let searchIndex: SearchItem[] = [];

  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const searchResults = document.getElementById('search-results') as HTMLDivElement;

  // Cargar índice
  async function loadSearchIndex() {
    try {
      const response = await fetch('/software-tools/search-index.json');
      searchIndex = await response.json();
      
      fuse = new Fuse(searchIndex, {
        keys: [
          { name: 'name', weight: 0.4 },
          { name: 'tags', weight: 0.3 },
          { name: 'context', weight: 0.2 },
          { name: 'category', weight: 0.1 },
        ],
        threshold: 0.3,
        includeScore: true,
        includeMatches: true,
      });
    } catch (error) {
      console.error('Error cargando índice de búsqueda:', error);
    }
  }

  // Realizar búsqueda
  function performSearch(query: string) {
    if (!fuse || !query.trim()) {
      searchResults.classList.add('hidden');
      return;
    }

    const results = fuse.search(query, { limit: 10 });
    
    if (results.length === 0) {
      searchResults.innerHTML = `
        <div class="p-4 text-slate-500 text-center">
          No se encontraron resultados
        </div>
      `;
      searchResults.classList.remove('hidden');
      return;
    }

    const html = results.map(result => {
      const tool = result.item;
      return `
        <a
          href="/software-tools/tools/${tool.slug}"
          class="block p-4 hover:bg-slate-700 transition-colors border-b border-slate-700 last:border-0"
        >
          <div class="flex items-start justify-between">
            <div>
              <h4 class="font-semibold text-white">${tool.name}</h4>
              <p class="text-sm text-slate-400 line-clamp-1">${tool.context}</p>
            </div>
            <span class="text-sm text-slate-500 bg-slate-900 px-2 py-1 rounded shrink-0 ml-2">
              ${tool.year}
            </span>
          </div>
          <div class="flex flex-wrap gap-2 mt-2">
            ${tool.tags.slice(0, 3).map(tag => `
              <span class="text-xs text-slate-500">#${tag}</span>
            `).join('')}
          </div>
        </a>
      `;
    }).join('');

    searchResults.innerHTML = html;
    searchResults.classList.remove('hidden');
  }

  // Event listeners
  searchInput?.addEventListener('input', (e) => {
    const query = (e.target as HTMLInputElement).value;
    performSearch(query);
  });

  // Cerrar resultados al hacer click fuera
  document.addEventListener('click', (e) => {
    const container = document.getElementById('search-container');
    if (container && !container.contains(e.target as Node)) {
      searchResults?.classList.add('hidden');
    }
  });

  // Atajo de teclado: / para enfocar
  document.addEventListener('keydown', (e) => {
    if (e.key === '/' && document.activeElement !== searchInput) {
      e.preventDefault();
      searchInput?.focus();
    }
    if (e.key === 'Escape') {
      searchResults?.classList.add('hidden');
      searchInput?.blur();
    }
  });

  // Cargar índice al iniciar
  loadSearchIndex();
</script>