---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from '../../utils/collection';

const tools = await getCollection('tools');
const publishedTools = tools.filter(t => t.published);
---

<Layout title="Todas las herramientas">
  <Header slot="header" />
  
  <div class="max-w-6xl mx-auto">
    <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">
      Todas las herramientas
    </h1>
    <p class="text-slate-400 mb-8">
      {publishedTools.length} herramientas documentadas en {Math.ceil((2025 - 1995) / 10)} décadas
    </p>

    {publishedTools.length === 0 ? (
      <div class="text-center py-16">
        <div class="text-6xl mb-4">🛠️</div>
        <h2 class="text-xl font-semibold text-white mb-2">
          Aún no hay herramientas documentadas
        </h2>
        <p class="text-slate-400">
          Las herramientas aparecerán aquí cuando se agreguen a <code class="bg-slate-800 px-2 py-1 rounded">src/content/tools/</code>
        </p>
      </div>
    ) : (
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {publishedTools.map(tool => (
          <a 
            href={`/tools/${tool.slug}`}
            class="bg-slate-800 hover:bg-slate-750 border border-slate-700 rounded-lg p-6 transition-all hover:border-sky-500/50 group"
          >
            <div class="flex items-start justify-between mb-3">
              <h3 class="text-lg font-semibold text-white group-hover:text-sky-400 transition-colors">
                {tool.name}
              </h3>
              <span class="text-sm text-slate-500 bg-slate-900 px-2 py-1 rounded">
                {tool.year}
              </span>
            </div>
            {tool.context && (
              <p class="text-slate-400 text-sm line-clamp-3 mb-4">
                {tool.context}
              </p>
            )}
            <div class="flex items-center justify-between">
              <div class="flex flex-wrap gap-2">
                {tool.tags.slice(0, 3).map(tag => (
                  <span class="text-xs text-slate-500 bg-slate-900 px-2 py-1 rounded">
                    #{tag}
                  </span>
                ))}
              </div>
              <span class="text-xs text-slate-600 uppercase tracking-wide">
                {tool.category}
              </span>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>

  <Footer slot="footer" />
</Layout>