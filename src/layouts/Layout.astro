---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Archivo histórico de herramientas utilizadas en 20+ años de docencia e ingeniería" } = Astro.props;
---

<!DOCTYPE html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | software-tools</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body class="bg-slate-950 text-slate-200 font-sans min-h-screen flex flex-col">
    <slot name="header" />
    <main class="flex-1 container mx-auto px-4 py-8 max-w-6xl">
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>